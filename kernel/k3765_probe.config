# Shadow-MSM K3765-Z first-handoff probe configuration.
# Merge this over Linux v6.1 multi_v5_defconfig.

CONFIG_LOCALVERSION="-shadow-msm-probe"
# CONFIG_LOCALVERSION_AUTO is not set

# Keep only the generic ARMv5/ARM926 core.
# CONFIG_ARCH_MULTI_V4 is not set
# CONFIG_ARCH_MULTI_V4T is not set
CONFIG_ARCH_MULTI_V5=y
# CONFIG_ARCH_MULTI_V6_V7 is not set
CONFIG_CPU_ARM926T=y
# CONFIG_VFP is not set
CONFIG_AEABI=y
# CONFIG_OABI_COMPAT is not set
# CONFIG_SMP is not set
# CONFIG_HIGHMEM is not set
CONFIG_AUTO_ZRELADDR=y
CONFIG_ARM_PATCH_PHYS_VIRT=y

# Generic DT-only handoff.
CONFIG_USE_OF=y
CONFIG_OF=y
# CONFIG_ARM_APPENDED_DTB is not set
# CONFIG_ARM_ATAG_DTB_COMPAT is not set

# Remove unrelated multi_v5 platforms and their driver selections.
# CONFIG_ARCH_ASPEED is not set
# CONFIG_ARCH_AT91 is not set
# CONFIG_ARCH_DAVINCI is not set
# CONFIG_ARCH_MXC is not set
# CONFIG_ARCH_MVEBU is not set
# CONFIG_ARCH_NPCM is not set
# CONFIG_ARCH_ORION5X is not set
# CONFIG_ARCH_SUNXI is not set
# CONFIG_ARCH_VERSATILE is not set

# Make the first probe small enough to leave the resident runtime intact.
CONFIG_EMBEDDED=y
CONFIG_EXPERT=y
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
# CONFIG_SWAP is not set
# CONFIG_SYSVIPC is not set
# CONFIG_CGROUPS is not set
# CONFIG_PROFILING is not set
# CONFIG_KPROBES is not set
# CONFIG_MODULES is not set
# CONFIG_NET is not set
# CONFIG_PCI is not set
# CONFIG_MTD is not set
# CONFIG_BLOCK is not set
# CONFIG_SCSI is not set
# CONFIG_ATA is not set
# CONFIG_INPUT is not set
# CONFIG_I2C is not set
# CONFIG_SPI is not set
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_SOUND is not set
# CONFIG_USB_SUPPORT is not set
# CONFIG_MMC is not set
# CONFIG_NEW_LEDS is not set
# CONFIG_RTC_CLASS is not set
# CONFIG_DMADEVICES is not set
# CONFIG_STAGING is not set
# CONFIG_IIO is not set
# CONFIG_BLK_DEV_INITRD is not set
# CONFIG_BINFMT_ELF is not set

# Deterministic early bring-up behavior.
# CONFIG_NO_HZ_IDLE is not set
# CONFIG_HIGH_RES_TIMERS is not set
CONFIG_HZ_100=y
CONFIG_PREEMPT_NONE=y
# CONFIG_PREEMPT is not set
CONFIG_PRINTK=y
CONFIG_LOG_BUF_SHIFT=15
CONFIG_DEBUG_KERNEL=y
CONFIG_DEBUG_INFO_NONE=y
# CONFIG_FTRACE is not set
# CONFIG_SCHED_DEBUG is not set
# CONFIG_DEBUG_PREEMPT is not set
CONFIG_SHADOW_MSM_EARLY_TRACE=y

CONFIG_KERNEL_GZIP=y
# CONFIG_KERNEL_LZMA is not set
# CONFIG_KERNEL_XZ is not set
# CONFIG_KERNEL_LZO is not set
# CONFIG_KERNEL_LZ4 is not set
