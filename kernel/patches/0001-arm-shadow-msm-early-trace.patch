From: Shadow-MSM contributors
Subject: [PATCH] ARM: add K3765-Z resident-runtime early trace

This experimental out-of-tree patch provides observable zImage decompressor
and early kernel-entry milestones on the ZTE K3765-Z. It calls the initialized,
RAM-resident ARMPRG diagnostic string routine at physical address 0x00816cf4.
A dedicated trace stack lives at 0x008ff000 because Linux repurposes r13
before the ARM926 setup callback. A temporary non-cacheable identity map keeps
the resident runtime reachable across the first MMU transition. Additional
checkpoints bracket __mmap_switched, BSS clearing, the start_kernel branch,
early generic initialization, ARM device-tree setup, and the paging_init
boundary. The device tree keeps the entire monitor window reserved.

This patch is intentionally device-specific and is not suitable for a generic
ARM kernel.

diff --git a/arch/arm/Kconfig.debug b/arch/arm/Kconfig.debug
index c345775..713af98 100644
--- a/arch/arm/Kconfig.debug
+++ b/arch/arm/Kconfig.debug
@@ -1918,6 +1918,15 @@ config DEBUG_UNCOMPRESS
 	  When this option is set, the selected DEBUG_LL output method
 	  will be re-used for normal decompressor output on multiplatform
 	  kernels.
+
+config SHADOW_MSM_EARLY_TRACE
+	bool "Shadow-MSM early trace through the resident ARMPRG runtime"
+	depends on CPU_ARM926T
+	help
+	  Emit RAM-only K3765-Z decompressor and pre-MMU kernel milestones
+	  through the initialized ARMPRG diagnostic transport at physical
+	  address 0x00816cf4. This is an experimental Shadow-MSM bring-up
+	  option and is not portable to other ARM926 systems.
 	  
 
 config UNCOMPRESS_INCLUDE
diff --git a/arch/arm/boot/compressed/misc.c b/arch/arm/boot/compressed/misc.c
index abfed1a..19d6598 100644
--- a/arch/arm/boot/compressed/misc.c
+++ b/arch/arm/boot/compressed/misc.c
@@ -91,6 +91,17 @@ static void putstr(const char *ptr)
 {
 	char c;
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	/*
+	 * Shadow-MSM enters the zImage while the initialized OEM ARMPRG
+	 * runtime is still resident at 0x00800000. Its bounded diagnostic
+	 * string transmitter provides an observable pre-MMU console without
+	 * touching persistent storage.
+	 */
+	((void (*)(const char *))0x00816cf4UL)(ptr);
+	return;
+#endif
+
 	while ((c = *ptr++) != '\0') {
 		if (c == '\n')
 			putc('\r');
diff --git a/arch/arm/kernel/head.S b/arch/arm/kernel/head.S
index 29e2900..c919cd3 100644
--- a/arch/arm/kernel/head.S
+++ b/arch/arm/kernel/head.S
@@ -104,12 +104,22 @@ ENTRY(stext)
 	@ ensure svc mode and all interrupts masked
 	safe_svcmode_maskall r9
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	adr_l	r11, .Lshadow_msm_entered
+	bl	__shadow_msm_trace
+#endif
+
 	mrc	p15, 0, r9, c0, c0		@ get processor id
 	bl	__lookup_processor_type		@ r5=procinfo r9=cpuid
 	movs	r10, r5				@ invalid processor (r5=0)?
  THUMB( it	eq )		@ force fixup-able long branch encoding
 	beq	__error_p			@ yes, error 'p'
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	adr_l	r11, .Lshadow_msm_cpu_ok
+	bl	__shadow_msm_trace
+#endif
+
 #ifdef CONFIG_ARM_LPAE
 	mrc	p15, 0, r3, c0, c1, 4		@ read ID_MMFR0
 	and	r3, r3, #0xf			@ extract VMSA support
@@ -138,6 +148,16 @@ ENTRY(stext)
 #endif
 	bl	__create_page_tables
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	adr_l	r11, .Lshadow_msm_tables_ok
+	bl	__shadow_msm_trace
+#endif
+
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	adr_l	r11, .Lshadow_msm_cpu_setup
+	bl	__shadow_msm_trace
+#endif
+
 	/*
 	 * The following calls CPU specific code in a position independent
 	 * manner.  See arch/arm/mm/proc-*.S for details.  r10 = base of
@@ -169,10 +189,53 @@ ENTRY(stext)
 	ldr	r12, [r10, #PROCINFO_INITFUNC]
 	add	r12, r12, r10
 	ret	r12
-1:	b	__enable_mmu
+1:
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	adr_l	r11, .Lshadow_msm_cpu_setup_returned
+	bl	__shadow_msm_trace
+#endif
+	b	__enable_mmu
 ENDPROC(stext)
 	.ltorg
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+/*
+ * Linux intentionally repurposes r13 as the future virtual
+ * __mmap_switched address before the processor setup callback. A trace after
+ * that point must not push to the apparent stack. Switch to a dedicated
+ * physical stack inside the monitor's reserved 0x00800000..0x008fffff
+ * window, preserve the Linux entry-contract registers and condition flags,
+ * then restore the original r13. r3 and r11 are scratch at every call site.
+ */
+ENTRY(__shadow_msm_trace)
+	mov	r3, sp
+	ldr	sp, =0x008ff000
+	push	{r0-r12, lr}
+	mrs	r12, cpsr
+	push	{r12, lr}
+	mov	r0, r11
+	ldr	r3, =0x00816cf4
+	blx	r3
+	pop	{r12, lr}
+	msr	cpsr_f, r12
+	pop	{r0-r12, lr}
+	mov	sp, r3
+	bx	lr
+ENDPROC(__shadow_msm_trace)
+
+.Lshadow_msm_entered:
+	.asciz	"Shadow-MSM: entered decompressed Linux head.S\r\n"
+.Lshadow_msm_cpu_ok:
+	.asciz	"Shadow-MSM: ARM926 processor lookup passed\r\n"
+.Lshadow_msm_tables_ok:
+	.asciz	"Shadow-MSM: initial page tables created\r\n"
+.Lshadow_msm_cpu_setup:
+	.asciz	"Shadow-MSM: calling ARM926 processor setup\r\n"
+.Lshadow_msm_cpu_setup_returned:
+	.asciz	"Shadow-MSM: ARM926 setup returned; enabling MMU next\r\n"
+	.align	2
+#endif
+
 /*
  * Setup the initial page tables.  We only setup the barest
  * amount which are required to get the kernel running, which
@@ -228,6 +228,18 @@ __create_page_tables:
 #endif
 #endif
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	ldr	r7, [r10, #PROCINFO_IO_MMUFLAGS]
+	mov	r0, r4
+	mov	r5, #0
+	mov	r6, #0x1000
+2:	orr	r3, r7, r5, lsl #SECTION_SHIFT
+	str	r3, [r0], #1 << PMD_ENTRY_ORDER
+	add	r5, r5, #1
+	subs	r6, r6, #1
+	bne	2b
+#endif
+
 	ldr	r7, [r10, #PROCINFO_MM_MMUFLAGS] @ mm_mmuflags
 
 	/*
@@ -503,11 +515,20 @@ ENTRY(__turn_mmu_on)
 	mcr	p15, 0, r0, c1, c0, 0		@ write control reg
 	mrc	p15, 0, r3, c0, c0, 0		@ read id reg
 	instr_sync
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	adr_l	r11, .Lshadow_msm_mmu_enabled
+	bl	__shadow_msm_trace
+#endif
 	mov	r3, r3
 	mov	r3, r13
 	ret	r3
 __turn_mmu_on_end:
 ENDPROC(__turn_mmu_on)
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+.Lshadow_msm_mmu_enabled:
+	.asciz	"Shadow-MSM: MMU enabled; identity execution continues\r\n"
+	.align	2
+#endif
 	.popsection
 
 
diff --git a/arch/arm/kernel/head-common.S b/arch/arm/kernel/head-common.S
--- a/arch/arm/kernel/head-common.S
+++ b/arch/arm/kernel/head-common.S
@@ -75,6 +75,10 @@
  */
 	__INIT
 __mmap_switched:
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	adr_l	r11, .Lshadow_msm_mmap_entered
+	bl	__shadow_msm_trace
+#endif
 
 	mov	r7, r1
 	mov	r8, r2
@@ -104,6 +108,10 @@ __mmap_switched:
 	sub	r2, r1, r0
 	mov	r1, #0
 	bl	__memset			@ clear .bss
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	adr_l	r11, .Lshadow_msm_bss_cleared
+	bl	__shadow_msm_trace
+#endif
 
 	adr_l	r0, init_task			@ get swapper task_struct
 	set_current r0, r1
@@ -117,9 +125,23 @@ __mmap_switched:
 #ifdef CONFIG_KASAN
 	bl	kasan_early_init
 #endif
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	adr_l	r11, .Lshadow_msm_start_kernel
+	bl	__shadow_msm_trace
+#endif
 	mov	lr, #0
 	b	start_kernel
 ENDPROC(__mmap_switched)
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+.Lshadow_msm_mmap_entered:
+	.asciz	"Shadow-MSM: entered __mmap_switched at the kernel virtual address\r\n"
+.Lshadow_msm_bss_cleared:
+	.asciz	"Shadow-MSM: __mmap_switched cleared BSS\r\n"
+.Lshadow_msm_start_kernel:
+	.asciz	"Shadow-MSM: branching to start_kernel\r\n"
+	.align	2
+#endif
+
 	.align	2
 	.type	__mmap_switched_data, %object
 __mmap_switched_data:
diff --git a/init/main.c b/init/main.c
index aa21add..20a7274 100644
--- a/init/main.c
+++ b/init/main.c
@@ -933,17 +933,36 @@ static void __init print_unknown_bootoptions(void)
 	memblock_free(unknown_options, len);
 }
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+static __always_inline void shadow_msm_c_trace(const char *message)
+{
+	((void (*)(const char *))0x00816cf4UL)(message);
+}
+#endif
+
 asmlinkage __visible void __init __no_sanitize_address start_kernel(void)
 {
 	char *command_line;
 	char *after_dashes;
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	shadow_msm_c_trace("Shadow-MSM: entered start_kernel C code\r\n");
+#endif
 	set_task_stack_end_magic(&init_task);
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	shadow_msm_c_trace("Shadow-MSM: initial task stack is ready\r\n");
+#endif
 	smp_setup_processor_id();
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	shadow_msm_c_trace("Shadow-MSM: processor ID setup completed\r\n");
+#endif
 	debug_objects_early_init();
 	init_vmlinux_build_id();
 
 	cgroup_init_early();
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	shadow_msm_c_trace("Shadow-MSM: earliest generic initialization completed\r\n");
+#endif
 
 	local_irq_disable();
 	early_boot_irqs_disabled = true;
@@ -956,6 +975,9 @@ asmlinkage __visible void __init __no_sanitize_address start_kernel(void)
 	page_address_init();
 	pr_notice("%s", linux_banner);
 	early_security_init();
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	shadow_msm_c_trace("Shadow-MSM: entering ARM setup_arch\r\n");
+#endif
 	setup_arch(&command_line);
 	setup_boot_config();
 	setup_command_line(command_line);
diff --git a/arch/arm/kernel/setup.c b/arch/arm/kernel/setup.c
index cb88c6e..8b58de7 100644
--- a/arch/arm/kernel/setup.c
+++ b/arch/arm/kernel/setup.c
@@ -83,6 +83,13 @@ extern void adjust_lowmem_bounds(void);
 extern enum reboot_mode reboot_mode;
 extern void setup_dma_zone(const struct machine_desc *desc);
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+static __always_inline void shadow_msm_arch_trace(const char *message)
+{
+	((void (*)(const char *))0x00816cf4UL)(message);
+}
+#endif
+
 unsigned int processor_id;
 EXPORT_SYMBOL(processor_id);
 unsigned int __machine_arch_type __read_mostly;
@@ -1097,10 +1104,16 @@ void __init setup_arch(char **cmdline_p)
 	const struct machine_desc *mdesc = NULL;
 	void *atags_vaddr = NULL;
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	shadow_msm_arch_trace("Shadow-MSM: entered setup_arch\r\n");
+#endif
 	if (__atags_pointer)
 		atags_vaddr = FDT_VIRT_BASE(__atags_pointer);
 
 	setup_processor();
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	shadow_msm_arch_trace("Shadow-MSM: setup_processor completed\r\n");
+#endif
 	if (atags_vaddr) {
 		mdesc = setup_machine_fdt(atags_vaddr);
 		if (mdesc)
@@ -1121,6 +1134,9 @@ void __init setup_arch(char **cmdline_p)
 	machine_desc = mdesc;
 	machine_name = mdesc->name;
 	dump_stack_set_arch_desc("%s", mdesc->name);
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	shadow_msm_arch_trace("Shadow-MSM: device-tree machine selected\r\n");
+#endif
 
 	if (mdesc->reboot_mode != REBOOT_HARD)
 		reboot_mode = mdesc->reboot_mode;
@@ -1138,6 +1154,9 @@ void __init setup_arch(char **cmdline_p)
 
 #ifdef CONFIG_MMU
 	early_mm_init(mdesc);
+#endif
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	shadow_msm_arch_trace("Shadow-MSM: early_mm_init completed\r\n");
 #endif
 	setup_dma_zone(mdesc);
 	xen_early_init();
@@ -1150,9 +1169,15 @@ void __init setup_arch(char **cmdline_p)
 	arm_memblock_init(mdesc);
 	/* Memory may have been removed so recalculate the bounds. */
 	adjust_lowmem_bounds();
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	shadow_msm_arch_trace("Shadow-MSM: ARM memblock initialization completed\r\n");
+#endif
 
 	early_ioremap_reset();
 
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	shadow_msm_arch_trace("Shadow-MSM: entering paging_init\r\n");
+#endif
 	paging_init(mdesc);
 	kasan_init();
 	request_standard_resources(mdesc);
diff --git a/arch/arm/mm/proc-arm926.S b/arch/arm/mm/proc-arm926.S
index 134426e..b5aaf97 100644
--- a/arch/arm/mm/proc-arm926.S
+++ b/arch/arm/mm/proc-arm926.S
@@ -455,12 +455,25 @@ ENDPROC(cpu_arm926_do_resume)
 
 	.type	__arm926_setup, #function
 __arm926_setup:
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	mov	r7, lr
+	adr_l	r11, .Lshadow_msm_arm926_entered
+	bl	__shadow_msm_trace
+#endif
 	mov	r0, #0
 	mcr	p15, 0, r0, c7, c7		@ invalidate I,D caches on v4
+#ifdef CONFIG_SHADOW_MSM_EARLY_TRACE
+	adr_l	r11, .Lshadow_msm_arm926_cache_ok
+	bl	__shadow_msm_trace
+#endif
 	mcr	p15, 0, r0, c7, c10, 4		@ drain write buffer on v4
 #ifdef CONFIG_MMU
